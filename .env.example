# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobmatch

# ---------------------------------------------------------------
# LLM provider  (claude | openai | gemini)
# ---------------------------------------------------------------
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Uncomment when switching providers:
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ---------------------------------------------------------------
# Email — SendGrid
# ---------------------------------------------------------------
SENDGRID_API_KEY=SG....
FROM_EMAIL=digest@jobmatch.app
FROM_NAME=JobMatch
DIGEST_TOP_N=10

# ---------------------------------------------------------------
# Scheduler  (daily pipeline runs at HOUR:MINUTE in TIMEZONE)
# ---------------------------------------------------------------
PIPELINE_CRON_HOUR=8
PIPELINE_CRON_MINUTE=0
PIPELINE_TIMEZONE=UTC

# ---------------------------------------------------------------
# App
# ---------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------
# Frontend URL — used in email links (no trailing slash)
# ---------------------------------------------------------------
FRONTEND_URL=https://jobmatch-dev-static.onrender.com

# ---------------------------------------------------------------
# Extra CORS origins — comma-separated, added to the default list
# ---------------------------------------------------------------
ALLOWED_ORIGINS=https://stellamatch.onrender.com
